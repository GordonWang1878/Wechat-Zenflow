<!-- pages/home/home.wxml -->
<view class="md-screen">

  <!-- 绿色英雄 header -->
  <view class="home-hero">
    <!-- 品牌名称（顶部固定显示） -->
    <view class="home-studio-row">
      <text class="home-studio-name">Zenflow</text>
      <text class="home-studio-sub">🌿 {{content.subtitle || '专业推拿 · 调理身心'}}</text>
    </view>
    <!-- 用户信息行 -->
    <view class="home-hero-bottom">
      <view class="home-user-info" bindtap="goToProfile">
        <text class="home-greeting">欢迎回来，{{userInfo.nickname || '用户'}} 👋</text>
        <text class="home-edit-hint">点击修改昵称 ›</text>
      </view>
      <view class="home-role-badge {{isAdmin ? 'badge-admin' : 'badge-member'}}">
        <text>{{isAdmin ? '👑 管理员' : '🌿 会员'}}</text>
      </view>
    </view>
  </view>

  <!-- loading -->
  <view class="md-card" wx:if="{{loading}}">
    <text class="loading-dots">···</text>
  </view>

  <block wx:else>

    <!-- 工作室介绍 -->
    <view class="md-card" wx:if="{{content.description}}">
      <view class="home-section-header">
        <text class="home-section-icon">📖</text>
        <text class="home-section-label">关于工作室</text>
      </view>
      <view class="md-divider" style="margin:16rpx 0 20rpx"></view>
      <text class="home-desc-body">{{content.description}}</text>
    </view>

    <!-- 服务项目 -->
    <view class="md-card" wx:if="{{content.services && content.services.length > 0}}">
      <view class="home-section-header">
        <text class="home-section-icon">🎯</text>
        <text class="home-section-label">服务项目</text>
      </view>
      <view class="md-divider" style="margin:16rpx 0"></view>
      <view class="home-svc-row" wx:for="{{content.services}}" wx:key="index">
        <text class="home-svc-name">{{item.name}}</text>
        <text class="home-svc-price">¥{{item.price}}</text>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="md-card" wx:if="{{content.contact || content.address}}">
      <view class="home-section-header">
        <text class="home-section-icon">📍</text>
        <text class="home-section-label">联系我们</text>
      </view>
      <view class="md-divider" style="margin:16rpx 0"></view>
      <view class="md-list-item" wx:if="{{content.contact}}">
        <view class="md-leading md-leading-surface"><text>📞</text></view>
        <text style="font-size:28rpx;color:#1C1B1F">{{content.contact}}</text>
      </view>
      <view class="md-list-item" wx:if="{{content.address}}">
        <view class="md-leading md-leading-surface"><text>📍</text></view>
        <text style="font-size:28rpx;color:#1C1B1F">{{content.address}}</text>
      </view>
    </view>

    <!-- 管理员入口 -->
    <block wx:if="{{isAdmin}}">
      <text class="md-section-title">管理员入口</text>
      <view class="home-admin-grid">
        <view class="home-admin-tile tile-primary" bindtap="goToMembers">
          <text class="tile-icon">👥</text>
          <text class="tile-label">会员管理</text>
        </view>
        <view class="home-admin-tile tile-secondary" bindtap="goToEditHome">
          <text class="tile-icon">✏️</text>
          <text class="tile-label">编辑主页</text>
        </view>
      </view>
    </block>

  </block>

  <!-- 退出登录 -->
  <view style="padding:16rpx 24rpx 40rpx">
    <view class="md-btn md-btn-outlined" bindtap="handleLogout">
      <text>退出登录</text>
    </view>
  </view>

</view>
