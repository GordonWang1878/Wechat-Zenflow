/* pages/home/home.wxss */
.home-page {
  background: #f5f5f0;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 顶部用户栏 */
.top-bar {
  background: #4a7c59;
  padding: 28rpx 30rpx 48rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.user-info { display: flex; align-items: center; gap: 16rpx; }
.greeting { color: #fff; font-size: 32rpx; font-weight: 600; }
.role-badge {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.role-badge.admin { background: rgba(255,255,255,0.25); color: #fff; }
.role-badge.guest { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.8); }
.logout-btn {
  color: rgba(255,255,255,0.7);
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

/* Loading */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

/* Banner */
.banner {
  background: linear-gradient(135deg, #4a7c59 0%, #2d5a3d 100%);
  margin: -24rpx 24rpx 24rpx;
  border-radius: 20rpx;
  padding: 52rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(74, 124, 89, 0.3);
}
.banner-title {
  display: block;
  font-size: 50rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 14rpx;
}
.banner-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 30rpx 24rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a7c59;
  display: block;
  margin-bottom: 20rpx;
}
.section-body {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* 服务项目 */
.service-list { display: flex; flex-direction: column; }
.service-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0ede5;
}
.service-row:last-child { border-bottom: none; }
.service-name { font-size: 28rpx; color: #333; }
.service-price { font-size: 30rpx; color: #c8956c; font-weight: 600; }

/* 联系方式 */
.contact-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}
.contact-label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
  padding-top: 2rpx;
}
.contact-val { font-size: 28rpx; color: #333; flex: 1; }

/* 管理面板 */
.admin-panel { border: 2rpx solid #e8f5e9; }
.admin-grid {
  display: flex;
  gap: 20rpx;
}
.admin-tile {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: #f8fdf9;
  border-radius: 16rpx;
}
.admin-tile:active { background: #e8f5e9; }
.tile-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}
.icon-members { background: #4a7c59; }
.icon-edit { background: #c8956c; }
.tile-label { font-size: 26rpx; color: #555; font-weight: 500; }
