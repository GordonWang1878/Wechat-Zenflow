/* pages/home/home.wxss */

/* 英雄 header */
.home-hero {
  background: #2E6640;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
}
.home-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 36rpx;
}
.home-greeting {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  margin-bottom: 8rpx;
}
.home-username {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.home-role-badge {
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.badge-admin { background: rgba(255,255,255,0.2); color: #FFFFFF; }
.badge-member { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }

.home-studio-row {}
.home-studio-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}
.home-studio-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 1rpx;
}

/* 内容卡片内部 */
.home-section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.home-section-icon { font-size: 36rpx; }
.home-section-label { font-size: 28rpx; font-weight: 600; color: #1C1B1F; }

.home-desc-body { font-size: 27rpx; color: #49454F; line-height: 1.8; }

.home-svc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.home-svc-row:last-child { border-bottom: none; }
.home-svc-name { font-size: 28rpx; color: #1C1B1F; }
.home-svc-price { font-size: 28rpx; font-weight: 700; color: #2E6640; }

/* 管理员入口 */
.home-admin-grid {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
}
.home-admin-tile {
  flex: 1;
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.tile-primary { background: #D4EDDA; }
.tile-secondary { background: #FDEBD0; }
.tile-icon { font-size: 52rpx; }
.tile-label { font-size: 28rpx; font-weight: 600; color: #1C1B1F; }
