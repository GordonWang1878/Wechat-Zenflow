/* pages/home/home.wxss */

/* 英雄 header */
.home-hero {
  background: #3D7D52;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 48rpx;
  margin-bottom: 20rpx;
}

/* 工作室名称（顶部大标题） */
.home-studio-row { margin-bottom: 32rpx; }
.home-studio-name {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  line-height: 1.15;
  margin-bottom: 10rpx;
}
.home-studio-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 1rpx;
}

/* 用户信息行（底部） */
.home-hero-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
}
.home-user-info {}
.home-greeting {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4rpx;
}
.home-edit-hint {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
}
.home-role-badge {
  padding: 10rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.badge-admin { background: rgba(255,255,255,0.2); color: #FFFFFF; }
.badge-member { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }

/* 内容卡片内部 */
.home-section-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.home-section-icon { font-size: 36rpx; }
.home-section-label { font-size: 28rpx; font-weight: 600; color: #1C1B1F; }

.home-desc-body { font-size: 27rpx; color: #49454F; line-height: 1.8; }

.home-svc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.home-svc-row:last-child { border-bottom: none; }
.home-svc-name { font-size: 28rpx; color: #1C1B1F; }
.home-svc-price { font-size: 28rpx; font-weight: 700; color: #3D7D52; }

/* 管理员入口 */
.home-admin-grid {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
}
.home-admin-tile {
  flex: 1;
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.tile-primary { background: #D4EDDA; }
.tile-secondary { background: #FDEBD0; }
.tile-icon { font-size: 52rpx; }
.tile-label { font-size: 28rpx; font-weight: 600; color: #1C1B1F; }
