/* pages/home/home.wxss */
.home-page {
  background: #F5F5F2;
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* 顶部栏 */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 28rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0E0DC;
}

.header-left { display: flex; align-items: center; gap: 16rpx; }

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111111;
}

.role-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 2rpx;
  letter-spacing: 1rpx;
}
.tag-admin { background: #111111; color: #FFFFFF; }
.tag-guest { background: #EEEEEA; color: #888888; }

.logout-link {
  font-size: 26rpx;
  color: #AAAAAA;
}

/* Loading */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #CCCCCC;
  font-size: 40rpx;
  letter-spacing: 8rpx;
}

/* 工作室名称区 */
.studio-hero {
  padding: 60rpx 40rpx 48rpx;
  border-bottom: 1rpx solid #E0E0DC;
  background: #FFFFFF;
}

.studio-name {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.studio-sub {
  display: block;
  font-size: 24rpx;
  color: #999999;
  letter-spacing: 2rpx;
}

/* 内容块 */
.content-block {
  margin: 0 40rpx;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #E0E0DC;
}

.block-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 20rpx;
}

.block-body {
  font-size: 28rpx;
  color: #444444;
  line-height: 1.9;
}

/* 服务项目 */
.service-list { display: flex; flex-direction: column; }
.service-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EEEEEA;
}
.service-row:last-child { border-bottom: none; }
.svc-name { font-size: 28rpx; color: #333333; }
.svc-price { font-size: 30rpx; color: #2E6640; font-weight: 600; }

/* 联系方式 */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}
.info-key {
  font-size: 24rpx;
  color: #AAAAAA;
  width: 80rpx;
  flex-shrink: 0;
  padding-top: 3rpx;
  letter-spacing: 1rpx;
}
.info-val { font-size: 28rpx; color: #333333; flex: 1; line-height: 1.6; }

/* 管理入口 */
.admin-block { border-bottom: none; }
.nav-list { display: flex; flex-direction: column; }
.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #EEEEEA;
}
.nav-row:last-child { border-bottom: none; }
.nav-row:active { opacity: 0.5; }
.nav-label { font-size: 30rpx; color: #111111; font-weight: 500; }
.nav-arrow { font-size: 36rpx; color: #CCCCCC; }
