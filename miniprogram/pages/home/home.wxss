/* pages/home/home.wxss */
.home-page { background: #EDEBE3; min-height: 100vh; }

/* hero card */
.home-hero-card {
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 36rpx;
}

.hero-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.hero-user-info { display: flex; align-items: center; gap: 14rpx; }
.hero-username { font-size: 26rpx; color: rgba(250,248,243,0.7); font-weight: 500; }

.role-tag-bento {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 5rpx 14rpx;
  border-radius: 6rpx;
}
.tag-admin-bento { background: #D4E6CC; color: #1B2B22; }
.tag-guest-bento { background: rgba(255,255,255,0.12); color: rgba(250,248,243,0.6); }

.logout-bento { font-size: 22rpx; color: rgba(250,248,243,0.4); letter-spacing: 1rpx; }

.home-studio-name {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #FAF8F3;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}
.home-studio-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(250,248,243,0.45);
  letter-spacing: 2rpx;
}

/* 介绍 */
.about-card {}
.about-body { font-size: 28rpx; color: #4A6050; line-height: 1.9; }

/* 服务 */
.services-card { min-height: 220rpx; }
.svc-row-bento {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(46,102,64,0.12);
}
.svc-row-bento:last-child { border-bottom: none; }
.svc-name-bento { font-size: 26rpx; color: #2C4A38; }
.svc-price-bento { font-size: 26rpx; color: #2E6640; font-weight: 700; }

/* 联系 */
.contact-card { min-height: 220rpx; }
.contact-row-bento {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  gap: 16rpx;
}
.contact-key-bento {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #B0AEA6;
  padding-top: 4rpx;
  flex-shrink: 0;
}
.contact-val-bento { font-size: 26rpx; color: #3A5544; flex: 1; line-height: 1.6; }

/* 管理 nav card */
.admin-nav-card { min-height: 200rpx; }
