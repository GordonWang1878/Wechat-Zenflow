/* pages/admin/edit-home/edit-home.wxss */
.edit-page {
  background: #f5f5f0;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

/* 分组卡片 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #4a7c59;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8f5e9;
}

/* 表单元素 */
.form-group { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 26rpx; color: #666; margin-bottom: 10rpx; }
.required { color: #e53935; }
.form-input {
  width: 100%;
  height: 84rpx;
  background: #f8f8f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.form-textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f8f8f5;
  border-radius: 10rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 服务列表 */
.service-list { margin-bottom: 20rpx; }
.service-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f0;
  gap: 12rpx;
}
.svc-name { flex: 1; font-size: 28rpx; color: #333; }
.svc-price { font-size: 28rpx; color: #c8956c; font-weight: 600; width: 120rpx; text-align: right; }
.svc-del {
  background: #ffeaea;
  color: #e53935;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

/* 新增服务行 */
.add-service-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}
.svc-input {
  flex: 1;
  height: 72rpx;
  background: #f8f8f5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
}
.svc-price-input {
  width: 140rpx;
  height: 72rpx;
  background: #f8f8f5;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
}
.svc-add-btn {
  background: #4a7c59;
  color: #fff;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  white-space: nowrap;
}

/* 提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.save-btn {
  width: 100%;
  height: 96rpx;
  background: #4a7c59;
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn::after { border: none; }
.save-btn.disabled { background: #93b89f; }
