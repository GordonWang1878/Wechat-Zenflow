/* pages/admin/edit-home/edit-home.wxss */

/* 标题 hero（复用 member-form 的样式） */
.form-hero {
  background: #2E6640;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}
.form-hero-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.form-hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}
.form-hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.6); }

/* 服务列表 */
.svc-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  gap: 16rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.svc-name { flex: 1; font-size: 28rpx; color: #1C1B1F; }
.svc-price { font-size: 28rpx; font-weight: 700; color: #2E6640; width: 100rpx; text-align: right; }
.svc-del { font-size: 28rpx; padding: 4rpx; }

/* 新增服务行 */
.add-svc-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.add-svc-name {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  color: #1C1B1F;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.add-svc-price {
  width: 120rpx;
  height: 72rpx;
  font-size: 26rpx;
  color: #1C1B1F;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  text-align: right;
}
.add-svc-btn {
  background: #2E6640;
  color: #FFFFFF;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

/* 提交按钮 */
.form-submit { width: 100%; height: 96rpx; font-size: 32rpx; }
