/* pages/admin/edit-home/edit-home.wxss */
.edit-bento-page { background: #EDEBE3; min-height: 100vh; }

.form-hero-card { min-height: 180rpx; display: flex; flex-direction: column; justify-content: flex-end; }
.form-hero-title { font-size: 52rpx; font-weight: 800; color: #FAF8F3; letter-spacing: -1rpx; margin-top: 8rpx; }

/* 表单行 */
.form-row-bento {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #EDEAE2;
  gap: 20rpx;
}
.form-row-bento:last-child { border-bottom: none; }
.form-row-textarea { align-items: flex-start; padding-top: 24rpx; }

.form-key-bento {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #B0AEA6;
  flex-shrink: 0;
  width: 64rpx;
  padding-top: 2rpx;
}
.req-dot { color: #B8694A; }

.form-val-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C4A38;
  height: 56rpx;
  background: transparent;
}

.form-val-textarea {
  flex: 1;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #2C4A38;
  background: transparent;
  line-height: 1.8;
  box-sizing: border-box;
}

/* 服务列表 */
.svc-item-bento {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(46,102,64,0.15);
  gap: 16rpx;
}
.svc-name-bento { flex: 1; font-size: 28rpx; color: #2C4A38; }
.svc-price-bento { font-size: 28rpx; font-weight: 700; color: #2E6640; width: 100rpx; text-align: right; }
.svc-del-bento { font-size: 22rpx; color: #B8694A; padding: 4rpx 0; }

/* 新增服务行 */
.add-svc-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 20rpx;
  margin-top: 4rpx;
}
.svc-name-input {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  color: #2C4A38;
  background: rgba(46,102,64,0.08);
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
}
.svc-price-input {
  width: 120rpx;
  height: 64rpx;
  font-size: 26rpx;
  color: #2C4A38;
  background: rgba(46,102,64,0.08);
  border-radius: 12rpx;
  padding: 0 16rpx;
  box-sizing: border-box;
  text-align: right;
}
.svc-add-btn {
  background: #2E6640;
  color: #FAF8F3;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}
