/* pages/admin/edit-home/edit-home.wxss */
.edit-page {
  background: #F5F5F2;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #CCCCCC;
  font-size: 40rpx;
  letter-spacing: 8rpx;
}

/* 分组卡片 */
.section-card {
  background: #FFFFFF;
  padding: 40rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
}

.section-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 32rpx;
}

/* 表单元素 */
.form-group { margin-bottom: 40rpx; }

.form-label {
  display: block;
  font-size: 20rpx;
  color: #AAAAAA;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}
.required { color: #C0392B; }

.form-input {
  width: 100%;
  height: 76rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 0;
  font-size: 30rpx;
  color: #111111;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
  line-height: 1.8;
}

/* 服务列表 */
.service-list { margin-bottom: 24rpx; }
.service-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0EC;
  gap: 16rpx;
}
.svc-name { flex: 1; font-size: 28rpx; color: #333333; }
.svc-price {
  font-size: 28rpx;
  color: #2E6640;
  font-weight: 600;
  width: 120rpx;
  text-align: right;
}
.svc-del {
  font-size: 22rpx;
  color: #C0392B;
  padding: 6rpx 0;
  letter-spacing: 1rpx;
}

/* 新增服务行 */
.add-service-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0EC;
}
.svc-input {
  flex: 1;
  height: 72rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 0;
  font-size: 26rpx;
  color: #111111;
}
.svc-price-input {
  width: 130rpx;
  height: 72rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 0;
  font-size: 26rpx;
  color: #111111;
  text-align: right;
}
.svc-add-btn {
  background: #111111;
  color: #FFFFFF;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

/* 提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E0E0DC;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.save-btn {
  width: 100%;
  height: 96rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-btn::after { border: none; }
.save-btn.disabled { opacity: 0.35; }
