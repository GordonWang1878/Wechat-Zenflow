<!-- pages/admin/edit-home/edit-home.wxml -->
<view class="md-screen" style="padding-bottom:160rpx">

  <!-- 标题 hero -->
  <view class="form-hero">
    <text class="form-hero-icon">🏠</text>
    <text class="form-hero-title">编辑主页</text>
    <text class="form-hero-sub">管理工作室对外展示内容</text>
  </view>

  <view class="md-card" wx:if="{{loading}}">
    <text class="loading-dots">···</text>
  </view>

  <block wx:else>

    <!-- 基本信息 -->
    <view class="md-card">
      <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:24rpx">
        <text style="font-size:32rpx">📖</text>
        <text style="font-size:28rpx;font-weight:700;color:#1C1B1F">基本信息</text>
      </view>

      <view class="md-field">
        <text class="md-field-label">标题 <text style="color:#B3261E">*</text></text>
        <view class="md-field-container">
          <input
            class="md-field-input"
            placeholder="例：禅流中医推拿"
            placeholder-style="color:#C8C8C8"
            value="{{form.title}}"
            bindinput="onInput"
            data-field="title"
            maxlength="30"
          />
        </view>
      </view>

      <view class="md-field">
        <text class="md-field-label">副标题</text>
        <view class="md-field-container">
          <input
            class="md-field-input"
            placeholder="例：专业推拿 · 调理身心"
            placeholder-style="color:#C8C8C8"
            value="{{form.subtitle}}"
            bindinput="onInput"
            data-field="subtitle"
            maxlength="40"
          />
        </view>
      </view>

      <view class="md-field" style="margin-bottom:0">
        <text class="md-field-label">工作室介绍</text>
        <view class="md-field-container">
          <textarea
            class="md-field-textarea"
            placeholder="介绍你的工作室..."
            placeholder-style="color:#C8C8C8"
            value="{{form.description}}"
            bindinput="onInput"
            data-field="description"
            maxlength="500"
            auto-height
          />
        </view>
      </view>
    </view>

    <!-- 服务项目 -->
    <view class="md-card">
      <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:24rpx">
        <text style="font-size:32rpx">🎯</text>
        <text style="font-size:28rpx;font-weight:700;color:#1C1B1F">服务项目</text>
      </view>

      <!-- 已有服务 -->
      <view wx:if="{{form.services && form.services.length > 0}}">
        <view class="svc-item" wx:for="{{form.services}}" wx:key="index">
          <text class="svc-name">{{item.name}}</text>
          <text class="svc-price">¥{{item.price}}</text>
          <view class="svc-del" bindtap="removeService" data-index="{{index}}">
            <text>🗑️</text>
          </view>
        </view>
        <view class="md-divider" style="margin:8rpx 0 20rpx"></view>
      </view>

      <!-- 新增服务行 -->
      <view class="add-svc-row">
        <input
          class="add-svc-name"
          placeholder="服务名称"
          placeholder-style="color:#C8C8C8"
          value="{{newServiceName}}"
          bindinput="onNewServiceInput"
          data-field="newServiceName"
        />
        <input
          class="add-svc-price"
          placeholder="价格"
          placeholder-style="color:#C8C8C8"
          type="digit"
          value="{{newServicePrice}}"
          bindinput="onNewServiceInput"
          data-field="newServicePrice"
        />
        <view class="add-svc-btn" bindtap="addService">
          <text>➕ 添加</text>
        </view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="md-card">
      <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:24rpx">
        <text style="font-size:32rpx">📍</text>
        <text style="font-size:28rpx;font-weight:700;color:#1C1B1F">联系方式</text>
      </view>

      <view class="md-field">
        <text class="md-field-label">📞 联系电话</text>
        <view class="md-field-container">
          <input
            class="md-field-input"
            placeholder="例：138-0000-0000"
            placeholder-style="color:#C8C8C8"
            value="{{form.contact}}"
            bindinput="onInput"
            data-field="contact"
            type="number"
            maxlength="20"
          />
        </view>
      </view>

      <view class="md-field" style="margin-bottom:0">
        <text class="md-field-label">📍 地址</text>
        <view class="md-field-container">
          <textarea
            class="md-field-textarea"
            placeholder="工作室详细地址"
            placeholder-style="color:#C8C8C8"
            value="{{form.address}}"
            bindinput="onInput"
            data-field="address"
            maxlength="100"
            auto-height
          />
        </view>
      </view>
    </view>

  </block>

  <!-- 保存按钮 -->
  <view style="padding:8rpx 24rpx 40rpx">
    <view
      class="md-btn md-btn-filled form-submit {{submitting ? 'disabled' : ''}}"
      bindtap="handleSubmit"
    >
      <text>{{submitting ? '保存中...' : '✅ 保存主页'}}</text>
    </view>
  </view>

</view>
