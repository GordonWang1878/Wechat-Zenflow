/* pages/admin/members/members.wxss */
.members-page { background: #EDEBE3; min-height: 100vh; }

/* Stats card */
.stats-card { padding-bottom: 24rpx; }
.stats-sub {
  display: block;
  font-size: 22rpx;
  color: #8A9A88;
  letter-spacing: 1rpx;
  margin-top: -4rpx;
  margin-bottom: 28rpx;
}

/* 搜索框 */
.search-bento {
  background: rgba(250,248,243,0.1);
  border-radius: 14rpx;
  padding: 16rpx 24rpx;
}
.search-input-bento {
  width: 100%;
  height: 52rpx;
  font-size: 28rpx;
  color: #FAF8F3;
}

/* 会员 card */
.member-item-card { padding: 28rpx 32rpx; }

.member-item-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-square {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #1B2B22;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-square text { font-size: 30rpx; color: #D4E6CC; font-weight: 700; }

.member-item-info { flex: 1; }
.member-item-top { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 6rpx; }
.member-item-name { font-size: 30rpx; font-weight: 700; color: #1B2B22; }
.member-item-no { font-size: 20rpx; color: #B0AEA6; letter-spacing: 1rpx; }
.member-item-phone { font-size: 24rpx; color: #8A9A88; }

.member-item-bal { text-align: right; flex-shrink: 0; }
.member-item-bal-num { font-size: 30rpx; font-weight: 800; color: #2E6640; }

.member-delete-link {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #B8694A;
  letter-spacing: 1rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EDEAE2;
}
