/* pages/admin/members/members.wxss */

/* 英雄 header */
.members-hero {
  background: #2E6640;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 20rpx;
}
.members-hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 4rpx;
}
.members-hero-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}
.members-hero-count {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.members-balance-box {
  background: rgba(255,255,255,0.12);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  text-align: right;
}
.members-balance-label {
  display: block;
  font-size: 20rpx;
  color: rgba(255,255,255,0.55);
  margin-bottom: 4rpx;
}
.members-balance-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* 会员卡片 */
.member-item { padding: 24rpx 28rpx 0; }

.member-item-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-bottom: 20rpx;
}

/* 头像圆形 */
.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #D4EDDA;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.member-avatar-text { font-size: 32rpx; font-weight: 700; color: #1B4332; }

.member-info { flex: 1; }
.member-info-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.member-name { font-size: 30rpx; font-weight: 700; color: #1C1B1F; }
.member-no-chip {
  background: #F0F0F0;
  border-radius: 50rpx;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  color: #9E9E9E;
  font-weight: 500;
}
.member-phone { font-size: 24rpx; color: #9E9E9E; }

.member-bal-box { text-align: right; flex-shrink: 0; }
.member-bal-num { font-size: 32rpx; font-weight: 700; color: #2E6640; }

/* Footer with delete */
.member-item-footer {
  border-top: 1rpx solid #F5F5F5;
  padding: 16rpx 0;
  display: flex;
  justify-content: flex-end;
}
.member-delete-btn { font-size: 24rpx; color: #B3261E; }

/* FAB */
.members-fab {
  position: fixed;
  bottom: 48rpx;
  right: 32rpx;
  background: #2E6640;
  border-radius: 32rpx;
  padding: 0 32rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(46,102,64,0.4);
}
.members-fab-icon { font-size: 36rpx; }
.members-fab-text { font-size: 28rpx; font-weight: 600; color: #FFFFFF; }
