<!-- pages/admin/members/members.wxml -->
<view class="md-screen" style="padding-bottom:160rpx">

  <!-- 绿色 header + 搜索 -->
  <view class="members-hero">
    <view class="members-hero-top">
      <view>
        <text class="members-hero-label">会员管理</text>
        <text class="members-hero-count">👥 {{members.length}} 位会员</text>
      </view>
      <view class="members-balance-box">
        <text class="members-balance-label">总余额</text>
        <text class="members-balance-num">¥{{totalBalance}}</text>
      </view>
    </view>
    <view class="md-search">
      <text style="font-size:30rpx">🔍</text>
      <input
        class="md-search-input"
        placeholder="搜索姓名 · 编号 · 手机"
        placeholder-style="color:rgba(255,255,255,0.4)"
        value="{{keyword}}"
        bindinput="onSearchInput"
      />
    </view>
  </view>

  <!-- loading -->
  <view class="md-card" wx:if="{{loading}}">
    <text class="loading-dots">···</text>
  </view>

  <!-- 暂无会员 -->
  <view class="md-card md-empty" wx:elif="{{members.length === 0}}">
    <text class="md-empty-icon">👤</text>
    <text class="md-empty-text">暂无会员，点击右下角新增</text>
  </view>

  <!-- 搜索无结果 -->
  <view class="md-card md-empty" wx:elif="{{filteredMembers.length === 0}}">
    <text class="md-empty-icon">🔍</text>
    <text class="md-empty-text">未找到「{{keyword}}」相关会员</text>
  </view>

  <!-- 会员列表 -->
  <block wx:else>
    <view
      class="md-card member-item"
      wx:for="{{filteredMembers}}"
      wx:key="_id"
    >
      <view class="member-item-main" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="member-avatar">
          <text class="member-avatar-text">{{item.name ? item.name[0] : '?'}}</text>
        </view>
        <view class="member-info">
          <view class="member-info-row">
            <text class="member-name">{{item.name}}</text>
            <view class="member-no-chip"><text>{{item.memberNo}}</text></view>
          </view>
          <text class="member-phone" wx:if="{{item.phone}}">📞 {{item.phone}}</text>
          <text class="member-phone" wx:else style="color:#E0E0E0">暂无手机号</text>
        </view>
        <view class="member-bal-box">
          <text class="member-bal-num">¥{{item.balance}}</text>
        </view>
      </view>
      <view class="member-item-footer">
        <text
          class="member-delete-btn"
          catchtap="deleteMember"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
        >🗑️ 删除</text>
      </view>
    </view>
  </block>

  <!-- FAB 新增会员 -->
  <view class="members-fab" bindtap="goToAdd">
    <text class="members-fab-icon">➕</text>
    <text class="members-fab-text">新增会员</text>
  </view>

</view>
