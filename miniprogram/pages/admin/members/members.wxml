<!-- pages/admin/members/members.wxml -->
<view class="members-page">
  <view class="bento-grid">

    <!-- Stats + 搜索：full，forest -->
    <view class="bento-card card-full card-forest stats-card">
      <text class="card-label" style="color:#8A9A88">Members</text>
      <text class="hero-number" style="color:#FAF8F3">{{members.length}}</text>
      <text class="stats-sub">位注册会员</text>
      <view class="search-bento">
        <input
          class="search-input-bento"
          placeholder="搜索姓名 / 编号 / 手机"
          placeholder-style="color:rgba(250,248,243,0.3)"
          value="{{keyword}}"
          bindinput="onSearchInput"
        />
      </view>
    </view>

    <!-- 总余额：half，sage -->
    <view class="bento-card card-half card-sage">
      <text class="card-label" style="color:#2E6640">Total Bal.</text>
      <text class="hero-number" style="font-size:48rpx;color:#1B2B22">¥{{totalBalance}}</text>
    </view>

    <!-- 新增按钮：half，terra -->
    <view class="bento-card card-half card-terra admin-nav-card" bindtap="goToAdd">
      <text class="card-label" style="color:#FAF8F3;opacity:0.55">New</text>
      <text class="admin-nav-title">新增会员</text>
      <text class="admin-nav-arrow">›</text>
    </view>

    <!-- loading -->
    <view class="bento-card card-full card-cream" wx:if="{{loading}}">
      <text class="loading-dots">···</text>
    </view>

    <!-- 无会员 -->
    <view class="bento-card card-full card-cream empty-bento"
          wx:elif="{{members.length === 0}}">
      <text class="empty-label">暂无会员，点击新增</text>
    </view>

    <!-- 搜索无结果 -->
    <view class="bento-card card-full card-cream empty-bento"
          wx:elif="{{filteredMembers.length === 0}}">
      <text class="empty-label">未找到「{{keyword}}」相关会员</text>
    </view>

    <!-- 会员卡片列表 -->
    <block wx:else>
      <view
        class="bento-card card-full card-cream member-item-card"
        wx:for="{{filteredMembers}}"
        wx:key="_id"
      >
        <view class="member-item-main" bindtap="goToDetail" data-id="{{item._id}}">
          <view class="avatar-square">
            <text>{{item.name ? item.name[0] : '?'}}</text>
          </view>
          <view class="member-item-info">
            <view class="member-item-top">
              <text class="member-item-name">{{item.name}}</text>
              <text class="member-item-no">{{item.memberNo}}</text>
            </view>
            <text class="member-item-phone" wx:if="{{item.phone}}">{{item.phone}}</text>
          </view>
          <view class="member-item-bal">
            <text class="card-label" style="margin-bottom:6rpx">Balance</text>
            <text class="member-item-bal-num">¥{{item.balance}}</text>
          </view>
        </view>
        <text
          class="member-delete-link"
          catchtap="deleteMember"
          data-id="{{item._id}}"
          data-name="{{item.name}}"
        >删除</text>
      </view>
    </block>

  </view>
</view>
