<!-- pages/admin/member-form/member-form.wxml -->
<view class="md-screen" style="padding-bottom:160rpx">

  <!-- 标题 header -->
  <view class="form-hero">
    <text class="form-hero-icon">{{isEdit ? '✏️' : '➕'}}</text>
    <text class="form-hero-title">{{isEdit ? '编辑会员' : '新增会员'}}</text>
    <text class="form-hero-sub">{{isEdit ? '修改会员资料' : '填写基本信息创建新会员'}}</text>
  </view>

  <!-- 基本信息 -->
  <view class="md-card">
    <text class="md-section-title" style="padding:0 0 20rpx">基本信息</text>

    <!-- 姓名 -->
    <view class="md-field">
      <text class="md-field-label">👤 姓名 <text style="color:#B3261E">*</text></text>
      <view class="md-field-container">
        <input
          class="md-field-input"
          placeholder="请输入姓名"
          placeholder-style="color:#C8C8C8"
          value="{{form.name}}"
          bindinput="onInput"
          data-field="name"
          maxlength="20"
        />
      </view>
    </view>

    <!-- 手机号 -->
    <view class="md-field">
      <text class="md-field-label">📞 手机号</text>
      <view class="md-field-container">
        <input
          class="md-field-input"
          placeholder="手机号（可选）"
          placeholder-style="color:#C8C8C8"
          value="{{form.phone}}"
          bindinput="onInput"
          data-field="phone"
          type="number"
          maxlength="11"
        />
      </view>
    </view>

    <!-- 性别 -->
    <view class="md-field">
      <text class="md-field-label">🚻 性别</text>
      <picker
        range="{{genderOptions}}"
        value="{{genderIndex}}"
        bindchange="onGenderChange"
      >
        <view class="md-field-container form-picker">
          <text class="form-picker-val">{{genderOptions[genderIndex]}}</text>
          <text class="form-picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 初始余额（仅新增） -->
    <view class="md-field" wx:if="{{!isEdit}}">
      <text class="md-field-label">🎯 初始点数</text>
      <view class="md-field-container">
        <input
          class="md-field-input"
          placeholder="默认为 0 点"
          placeholder-style="color:#C8C8C8"
          value="{{form.balance}}"
          bindinput="onInput"
          data-field="balance"
          type="digit"
        />
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="md-card">
    <view class="md-field" style="margin-bottom:0">
      <text class="md-field-label">📝 备注</text>
      <view class="md-field-container">
        <textarea
          class="md-field-textarea"
          placeholder="备注信息（可选，最多 200 字）"
          placeholder-style="color:#C8C8C8"
          value="{{form.notes}}"
          bindinput="onInput"
          data-field="notes"
          maxlength="200"
          auto-height
        />
      </view>
    </view>
  </view>

  <!-- 提交 -->
  <view style="padding:8rpx 24rpx 40rpx">
    <view
      class="md-btn md-btn-filled form-submit {{submitting ? 'disabled' : ''}}"
      bindtap="handleSubmit"
    >
      <text>{{submitting ? '提交中...' : (isEdit ? '✅ 保存修改' : '✅ 创建会员')}}</text>
    </view>
  </view>

</view>
