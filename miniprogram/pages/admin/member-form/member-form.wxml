<!-- pages/admin/member-form/member-form.wxml -->
<view class="form-bento-page">
  <view class="bento-grid">

    <!-- 英雄：full，forest -->
    <view class="bento-card card-full card-forest form-hero-card">
      <text class="card-label" style="color:#8A9A88">{{isEdit ? 'EDIT MEMBER' : 'NEW MEMBER'}}</text>
      <text class="form-hero-title">{{isEdit ? '编辑会员' : '新增会员'}}</text>
    </view>

    <!-- 基本信息：full，cream -->
    <view class="bento-card card-full card-cream">
      <text class="card-label">基本信息</text>

      <!-- 姓名 -->
      <view class="form-row-bento">
        <text class="form-key-bento">NAME <text class="req-dot">*</text></text>
        <input
          class="form-val-input"
          placeholder="请输入姓名"
          placeholder-style="color:#C8C6BE"
          value="{{form.name}}"
          bindinput="onInput"
          data-field="name"
          maxlength="20"
        />
      </view>

      <!-- 手机号 -->
      <view class="form-row-bento">
        <text class="form-key-bento">TEL</text>
        <input
          class="form-val-input"
          placeholder="手机号（可选）"
          placeholder-style="color:#C8C6BE"
          value="{{form.phone}}"
          bindinput="onInput"
          data-field="phone"
          type="number"
          maxlength="11"
        />
      </view>

      <!-- 性别 -->
      <view class="form-row-bento">
        <text class="form-key-bento">SEX</text>
        <picker
          range="{{genderOptions}}"
          value="{{genderIndex}}"
          bindchange="onGenderChange"
          style="flex:1"
        >
          <view class="form-picker-bento">
            <text class="form-picker-val">{{genderOptions[genderIndex]}}</text>
            <text class="form-picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <!-- 初始余额（仅新增时显示） -->
      <view class="form-row-bento" wx:if="{{!isEdit}}">
        <text class="form-key-bento">¥</text>
        <input
          class="form-val-input"
          placeholder="初始余额（默认 0）"
          placeholder-style="color:#C8C6BE"
          value="{{form.balance}}"
          bindinput="onInput"
          data-field="balance"
          type="digit"
        />
      </view>

    </view>

    <!-- 备注：full，sage -->
    <view class="bento-card card-full card-sage">
      <text class="card-label" style="color:#2E6640">Note</text>
      <textarea
        class="form-notes-bento"
        placeholder="备注（可选，最多 200 字）"
        placeholder-style="color:#8A9A88"
        value="{{form.notes}}"
        bindinput="onInput"
        data-field="notes"
        maxlength="200"
        auto-height
      />
    </view>

    <!-- 提交：full，forest -->
    <view
      class="bento-card card-full submit-card card-forest {{submitting ? 'disabled' : ''}}"
      bindtap="handleSubmit"
    >
      <text class="submit-card-text">
        {{submitting ? '提交中...' : (isEdit ? '保存修改' : '创建会员')}}
      </text>
    </view>

  </view>
</view>
