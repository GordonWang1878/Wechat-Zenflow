/* pages/admin/member-form/member-form.wxss */
.form-page {
  background: #f5f5f0;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.form-group { margin-bottom: 32rpx; }
.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.required { color: #e53935; }

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-display {
  height: 88rpx;
  background: #f8f8f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #333;
}
.picker-arrow { color: #aaa; font-size: 22rpx; }

.form-textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f8f8f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  background: #4a7c59;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 28rpx 0;
  width: 100%;
  text-align: center;
}
.btn-primary::after { border: none; }
.btn-primary.disabled { background: #93b89f; }
