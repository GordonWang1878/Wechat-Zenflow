/* pages/admin/member-form/member-form.wxss */
.form-page {
  background: #F5F5F2;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: 160rpx;
}

.form-card {
  background: #FFFFFF;
  padding: 48rpx 40rpx;
  margin-top: 24rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
}

.form-group { margin-bottom: 44rpx; }

.form-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}
.required { color: #C0392B; }

.form-input {
  width: 100%;
  height: 76rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 0;
  font-size: 30rpx;
  color: #111111;
  box-sizing: border-box;
}

.picker-display {
  height: 76rpx;
  border-bottom: 1rpx solid #E0E0DC;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  color: #111111;
}
.picker-arrow { color: #CCCCCC; font-size: 24rpx; }

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
  line-height: 1.8;
}

/* 底部提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E0E0DC;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }
.btn-primary.disabled { opacity: 0.35; }
