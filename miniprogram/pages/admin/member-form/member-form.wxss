/* pages/admin/member-form/member-form.wxss */

/* 标题 hero */
.form-hero {
  background: #3A3A3A;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}
.form-hero-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.form-hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}
.form-hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.6); }

/* Picker */
.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 52rpx;
}
.form-picker-val { font-size: 28rpx; color: #1C1B1F; }
.form-picker-arrow { font-size: 40rpx; color: #BDBDBD; line-height: 1; }

/* 提交按钮 */
.form-submit { width: 100%; height: 96rpx; font-size: 32rpx; }
