/* pages/admin/member-form/member-form.wxss */
.form-bento-page { background: #EDEBE3; min-height: 100vh; }

.form-hero-card { min-height: 180rpx; display: flex; flex-direction: column; justify-content: flex-end; }
.form-hero-title { font-size: 52rpx; font-weight: 800; color: #FAF8F3; letter-spacing: -1rpx; margin-top: 8rpx; }

/* 表单行 */
.form-row-bento {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #EDEAE2;
  gap: 20rpx;
}
.form-row-bento:last-child { border-bottom: none; }

.form-key-bento {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #B0AEA6;
  flex-shrink: 0;
  width: 64rpx;
}
.req-dot { color: #B8694A; }

.form-val-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C4A38;
  height: 56rpx;
  background: transparent;
}

.form-picker-bento {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56rpx;
}
.form-picker-val { font-size: 28rpx; color: #2C4A38; }
.form-picker-arrow { font-size: 36rpx; color: #B0AEA6; line-height: 1; }

/* 备注 */
.form-notes-bento {
  width: 100%;
  min-height: 100rpx;
  background: transparent;
  border: none;
  font-size: 28rpx;
  color: #2C4A38;
  line-height: 1.8;
  box-sizing: border-box;
  margin-top: 8rpx;
}
