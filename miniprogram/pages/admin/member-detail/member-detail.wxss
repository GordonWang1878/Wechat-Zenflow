/* pages/admin/member-detail/member-detail.wxss */

/* 余额英雄 header */
.detail-hero {
  background: #3D7D52;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
}
.detail-hero-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}
.detail-hero-balance-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 32rpx;
}
.detail-hero-balance {
  font-size: 80rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -3rpx;
  line-height: 1.1;
}
.detail-hero-unit {
  font-size: 32rpx;
  font-weight: 400;
  color: rgba(255,255,255,0.7);
}
.detail-hero-member {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.detail-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.detail-avatar-text { font-size: 32rpx; font-weight: 700; color: #FFFFFF; }
.detail-member-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}
.detail-member-meta {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 1rpx;
}

/* 操作按钮行 */
.detail-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 16rpx;
}
.detail-action-btn {
  flex: 1;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.btn-recharge { background: #D4EDDA; }
.btn-consume { background: #FDEBD0; }
.btn-edit { background: #F0F0F0; }
.detail-action-icon { font-size: 44rpx; }
.detail-action-text { font-size: 26rpx; font-weight: 600; color: #1C1B1F; }

/* 用于 home section header 复用 */
.home-section-header { display: flex; align-items: center; gap: 16rpx; }
.home-section-icon { font-size: 36rpx; }

/* 交易 header */
.detail-tx-header { padding: 28rpx 32rpx; }
.detail-tx-count-chip {
  background: #D4EDDA;
  border-radius: 50rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1B4332;
}

/* 交易条目 */
.tx-item { padding: 24rpx 28rpx; }
.tx-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.tx-type-chip {
  border-radius: 50rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}
.chip-recharge { background: #D4EDDA; color: #1B4332; }
.chip-consume { background: #FDEBD0; color: #7B3F26; }

.tx-amount { font-size: 36rpx; font-weight: 700; }
.amount-pos { color: #3D7D52; }
.amount-neg { color: #B8694A; }

.tx-item-bottom { display: flex; align-items: flex-end; justify-content: space-between; }
.tx-time { display: block; font-size: 22rpx; color: #9E9E9E; margin-bottom: 6rpx; }
.tx-notes { display: block; font-size: 24rpx; color: #49454F; }
.tx-after-bal { font-size: 22rpx; color: #9E9E9E; }
