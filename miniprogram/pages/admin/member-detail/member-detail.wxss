/* pages/admin/member-detail/member-detail.wxss */
.detail-page {
  background: #F5F5F2;
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #CCCCCC;
  font-size: 40rpx;
  letter-spacing: 8rpx;
}

/* 会员头部 */
.member-hero {
  background: #FFFFFF;
  padding: 48rpx 40rpx 40rpx;
  border-bottom: 1rpx solid #E0E0DC;
}

.hero-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.member-avatar text { font-size: 40rpx; color: #FFFFFF; font-weight: 700; }

.member-meta { flex: 1; }
.member-name { display: block; font-size: 40rpx; font-weight: 700; color: #111111; margin-bottom: 8rpx; }
.member-no { display: block; font-size: 22rpx; color: #AAAAAA; letter-spacing: 1rpx; }

.balance-display {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding-top: 32rpx;
  border-top: 1rpx solid #F0F0EC;
}
.balance-label-sm { font-size: 22rpx; color: #AAAAAA; letter-spacing: 2rpx; }
.balance-figure { font-size: 60rpx; font-weight: 700; color: #2E6640; letter-spacing: -1rpx; }

/* 操作按钮行 */
.action-row {
  display: flex;
  gap: 0;
  background: #FFFFFF;
  border-bottom: 1rpx solid #E0E0DC;
  margin-top: 24rpx;
}
.action-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border-right: 1rpx solid #E0E0DC;
}
.action-btn:last-child { border-right: none; }
.action-btn:active { opacity: 0.6; }

.btn-recharge { background: #111111; color: #FFFFFF; }
.btn-consume { background: #965F30; color: #FFFFFF; }
.btn-edit { background: #FFFFFF; color: #111111; }

/* 附加信息 */
.info-section {
  background: #FFFFFF;
  margin-top: 24rpx;
  padding: 0 40rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
}
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0EC;
}
.info-row:last-child { border-bottom: none; }
.info-key { font-size: 22rpx; color: #AAAAAA; width: 100rpx; flex-shrink: 0; letter-spacing: 1rpx; padding-top: 3rpx; }
.info-val { font-size: 28rpx; color: #333333; flex: 1; line-height: 1.6; }

/* 交易记录 */
.tx-section {
  background: #FFFFFF;
  margin-top: 24rpx;
  padding: 36rpx 40rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
}
.section-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
}

.empty-tx { padding: 40rpx 0; text-align: center; }
.empty-tx text { font-size: 26rpx; color: #CCCCCC; letter-spacing: 1rpx; }

.tx-list { display: flex; flex-direction: column; }
.tx-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F2;
}
.tx-row:last-child { border-bottom: none; }

.tx-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.tx-tag {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  padding: 5rpx 14rpx;
  border-radius: 2rpx;
  flex-shrink: 0;
}
.tag-in { background: #EEF6F0; color: #2E6640; }
.tag-out { background: #FDF5EE; color: #965F30; }

.tx-meta { flex: 1; }
.tx-time { display: block; font-size: 22rpx; color: #AAAAAA; }
.tx-notes { display: block; font-size: 24rpx; color: #666666; margin-top: 4rpx; }

.tx-right { text-align: right; flex-shrink: 0; }
.tx-amount { display: block; font-size: 32rpx; font-weight: 700; }
.amount-in { color: #2E6640; }
.amount-out { color: #965F30; }
.tx-after { display: block; font-size: 20rpx; color: #BBBBBB; margin-top: 4rpx; }
