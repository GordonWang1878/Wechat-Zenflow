/* pages/admin/member-detail/member-detail.wxss */
.detail-page { background: #EDEBE3; min-height: 100vh; }

/* 余额英雄 card */
.balance-hero-card {
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.balance-hero-num {
  display: block;
  font-size: 88rpx;
  font-weight: 800;
  color: #FAF8F3;
  letter-spacing: -4rpx;
  line-height: 1;
  margin: 12rpx 0 24rpx;
}
.balance-hero-member {}
.balance-hero-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(250,248,243,0.9);
  margin-bottom: 6rpx;
}
.balance-hero-meta {
  display: block;
  font-size: 22rpx;
  color: rgba(250,248,243,0.45);
  letter-spacing: 1rpx;
}

/* 联系信息 */
.info-card {}
.info-row-bento {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #EDEAE2;
  gap: 20rpx;
}
.info-row-bento:last-child { border-bottom: none; }
.info-key-bento {
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #B0AEA6;
  padding-top: 4rpx;
  flex-shrink: 0;
  width: 60rpx;
}
.info-val-bento { font-size: 28rpx; color: #3A5544; flex: 1; line-height: 1.6; }

/* 交易记录 header */
.tx-header-card { padding: 32rpx 36rpx; }
.tx-header-row { display: flex; align-items: baseline; gap: 12rpx; margin-top: 4rpx; }
.tx-header-sub { font-size: 22rpx; color: #8A9A88; letter-spacing: 1rpx; }

/* 交易 item */
.tx-item-card { padding: 28rpx 32rpx; }
.tx-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.tx-item-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.tx-tag-bento {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}
.tag-recharge { background: #D4E6CC; color: #2E6640; }
.tag-consume { background: rgba(184,105,74,0.15); color: #B8694A; }

.tx-item-amount { font-size: 36rpx; font-weight: 800; }
.amount-pos { color: #2E6640; }
.amount-neg { color: #B8694A; }

.tx-item-meta {}
.tx-item-time { display: block; font-size: 22rpx; color: #B0AEA6; }
.tx-item-notes { display: block; font-size: 24rpx; color: #5A7060; margin-top: 4rpx; }
.tx-item-after { font-size: 22rpx; color: #B0AEA6; letter-spacing: 1rpx; }
