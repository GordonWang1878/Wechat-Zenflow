/* pages/admin/member-detail/member-detail.wxss */
.detail-page {
  background: #f5f5f0;
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
  color: #999;
}

/* 会员信息卡片 */
.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.avatar-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}
.big-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #4a7c59;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.big-avatar text {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
}
.basic-info { flex: 1; }
.member-name { display: block; font-size: 40rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 6rpx; }
.member-no { display: block; font-size: 24rpx; color: #999; margin-bottom: 10rpx; }
.gender-tag {
  display: inline-block;
  background: #e8f5e9;
  color: #2e7d32;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.divider { height: 1rpx; background: #f0ede5; margin: 24rpx 0; }

.balance-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.balance-label { font-size: 28rpx; color: #666; }
.balance-value { font-size: 52rpx; font-weight: 700; color: #4a7c59; }

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
}
.info-label { font-size: 26rpx; color: #999; width: 100rpx; flex-shrink: 0; }
.info-val { font-size: 28rpx; color: #333; flex: 1; }

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}
.btn-recharge { background: #4a7c59; color: #fff; }
.btn-consume { background: #c8956c; color: #fff; }
.btn-edit { background: #fff; color: #4a7c59; border: 2rpx solid #4a7c59; }

/* 交易记录 */
.tx-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a7c59;
  display: block;
  margin-bottom: 24rpx;
}
.empty-state { padding: 40rpx 0; text-align: center; }
.empty-text { color: #bbb; font-size: 28rpx; }

.tx-list { display: flex; flex-direction: column; }
.tx-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f0;
}
.tx-row:last-child { border-bottom: none; }

.tx-left { display: flex; align-items: center; gap: 16rpx; flex: 1; }
.tx-type-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.tx-type-badge.recharge { background: #e8f5e9; color: #2e7d32; }
.tx-type-badge.consume { background: #fff3e0; color: #e65100; }

.tx-meta { flex: 1; }
.tx-time { display: block; font-size: 24rpx; color: #aaa; }
.tx-notes { display: block; font-size: 26rpx; color: #666; margin-top: 4rpx; }

.tx-right { text-align: right; flex-shrink: 0; }
.tx-amount { display: block; font-size: 32rpx; font-weight: 700; }
.amount-in { color: #2e7d32; }
.amount-out { color: #e65100; }
.tx-balance-after { display: block; font-size: 22rpx; color: #aaa; margin-top: 4rpx; }
