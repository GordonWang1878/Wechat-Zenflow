<!-- pages/admin/member-detail/member-detail.wxml -->
<view class="detail-page">

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap"><text>加载中...</text></view>

  <block wx:else>
    <!-- 会员信息卡片 -->
    <view class="info-card">
      <view class="avatar-row">
        <view class="big-avatar">
          <text>{{member.name ? member.name[0] : '?'}}</text>
        </view>
        <view class="basic-info">
          <text class="member-name">{{member.name}}</text>
          <text class="member-no">{{member.memberNo}}</text>
          <view class="gender-tag">{{member.gender || '未知'}}</view>
        </view>
      </view>

      <view class="divider"></view>

      <!-- 余额展示 -->
      <view class="balance-row">
        <text class="balance-label">账户余额</text>
        <text class="balance-value">¥ {{member.balance}}</text>
      </view>

      <view class="divider"></view>

      <!-- 详细信息 -->
      <view class="info-row" wx:if="{{member.phone}}">
        <text class="info-label">手机号</text>
        <text class="info-val">{{member.phone}}</text>
      </view>
      <view class="info-row" wx:if="{{member.notes}}">
        <text class="info-label">备注</text>
        <text class="info-val">{{member.notes}}</text>
      </view>
    </view>

    <!-- 操作按钮区 -->
    <view class="action-bar">
      <view
        class="action-btn btn-recharge"
        bindtap="goToTransaction"
        data-type="recharge"
      >
        <text>充值</text>
      </view>
      <view
        class="action-btn btn-consume"
        bindtap="goToTransaction"
        data-type="consume"
      >
        <text>消费</text>
      </view>
      <view class="action-btn btn-edit" bindtap="goToEdit">
        <text>编辑</text>
      </view>
    </view>

    <!-- 交易记录 -->
    <view class="tx-section">
      <text class="section-title">交易记录</text>

      <view wx:if="{{txLoading}}" class="loading-wrap"><text>加载中...</text></view>

      <view wx:elif="{{transactions.length === 0}}" class="empty-state">
        <text class="empty-text">暂无交易记录</text>
      </view>

      <view wx:else class="tx-list">
        <view
          class="tx-row"
          wx:for="{{transactions}}"
          wx:key="_id"
        >
          <view class="tx-left">
            <view class="tx-type-badge {{item.type === 'recharge' ? 'recharge' : 'consume'}}">
              <text>{{item.type === 'recharge' ? '充值' : '消费'}}</text>
            </view>
            <view class="tx-meta">
              <text class="tx-time">{{item.timeStr}}</text>
              <text class="tx-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
            </view>
          </view>
          <view class="tx-right">
            <text class="tx-amount {{item.type === 'recharge' ? 'amount-in' : 'amount-out'}}">
              {{item.type === 'recharge' ? '+' : '-'}}{{item.amount}}
            </text>
            <text class="tx-balance-after">余额 ¥{{item.balanceAfter}}</text>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
