<!-- pages/admin/member-detail/member-detail.wxml -->
<view class="detail-page">

  <view wx:if="{{loading}}" class="loading-wrap"><text>···</text></view>

  <block wx:else>

    <!-- 会员头部信息 -->
    <view class="member-hero">
      <view class="hero-top">
        <view class="member-avatar">
          <text>{{member.name ? member.name[0] : '?'}}</text>
        </view>
        <view class="member-meta">
          <text class="member-name">{{member.name}}</text>
          <text class="member-no">{{member.memberNo}} · {{member.gender || '未知'}}</text>
        </view>
      </view>

      <!-- 余额 -->
      <view class="balance-display">
        <text class="balance-label-sm">账户余额</text>
        <text class="balance-figure">¥ {{member.balance}}</text>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-row">
      <view class="action-btn btn-recharge" bindtap="goToTransaction" data-type="recharge">
        <text>充值</text>
      </view>
      <view class="action-btn btn-consume" bindtap="goToTransaction" data-type="consume">
        <text>消费</text>
      </view>
      <view class="action-btn btn-edit" bindtap="goToEdit">
        <text>编辑</text>
      </view>
    </view>

    <!-- 附加信息 -->
    <view class="info-section" wx:if="{{member.phone || member.notes}}">
      <view class="info-row" wx:if="{{member.phone}}">
        <text class="info-key">手机号</text>
        <text class="info-val">{{member.phone}}</text>
      </view>
      <view class="info-row" wx:if="{{member.notes}}">
        <text class="info-key">备注</text>
        <text class="info-val">{{member.notes}}</text>
      </view>
    </view>

    <!-- 交易记录 -->
    <view class="tx-section">
      <text class="section-label">交易记录</text>

      <view wx:if="{{txLoading}}" class="loading-wrap"><text>···</text></view>

      <view wx:elif="{{transactions.length === 0}}" class="empty-tx">
        <text>暂无记录</text>
      </view>

      <view wx:else class="tx-list">
        <view class="tx-row" wx:for="{{transactions}}" wx:key="_id">
          <view class="tx-left">
            <text class="tx-tag {{item.type === 'recharge' ? 'tag-in' : 'tag-out'}}">
              {{item.type === 'recharge' ? '充值' : '消费'}}
            </text>
            <view class="tx-meta">
              <text class="tx-time">{{item.timeStr}}</text>
              <text class="tx-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
            </view>
          </view>
          <view class="tx-right">
            <text class="tx-amount {{item.type === 'recharge' ? 'amount-in' : 'amount-out'}}">
              {{item.type === 'recharge' ? '+' : '−'}}{{item.amount}}
            </text>
            <text class="tx-after">余额 {{item.balanceAfter}}</text>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
