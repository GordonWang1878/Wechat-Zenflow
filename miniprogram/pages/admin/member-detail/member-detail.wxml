<!-- pages/admin/member-detail/member-detail.wxml -->
<view class="md-screen">

  <view class="md-card" wx:if="{{loading}}">
    <text class="loading-dots">···</text>
  </view>

  <block wx:else>

    <!-- 余额英雄 header -->
    <view class="detail-hero">
      <text class="detail-hero-label">当前余额</text>
      <text class="detail-hero-balance">¥ {{member.balance}}</text>
      <view class="detail-hero-member">
        <view class="detail-avatar">
          <text class="detail-avatar-text">{{member.name ? member.name[0] : '?'}}</text>
        </view>
        <view>
          <text class="detail-member-name">{{member.name}}</text>
          <text class="detail-member-meta">{{member.memberNo}} · {{member.gender || '未知'}}</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮行 -->
    <view class="detail-actions">
      <view class="detail-action-btn btn-recharge" bindtap="goToTransaction" data-type="recharge">
        <text class="detail-action-icon">💰</text>
        <text class="detail-action-text">充值</text>
      </view>
      <view class="detail-action-btn btn-consume" bindtap="goToTransaction" data-type="consume">
        <text class="detail-action-icon">🛒</text>
        <text class="detail-action-text">消费</text>
      </view>
      <view class="detail-action-btn btn-edit" bindtap="goToEdit">
        <text class="detail-action-icon">✏️</text>
        <text class="detail-action-text">编辑</text>
      </view>
    </view>

    <!-- 联系信息 -->
    <view class="md-card" wx:if="{{member.phone || member.notes}}">
      <view class="home-section-header">
        <text class="home-section-icon">📋</text>
        <text style="font-size:28rpx;font-weight:600;color:#1C1B1F">会员信息</text>
      </view>
      <view class="md-divider" style="margin:16rpx 0"></view>
      <view class="md-list-item" wx:if="{{member.phone}}">
        <view class="md-leading md-leading-surface"><text>📞</text></view>
        <view style="flex:1">
          <text style="font-size:20rpx;color:#9E9E9E;display:block;margin-bottom:4rpx">手机号</text>
          <text style="font-size:28rpx;color:#1C1B1F">{{member.phone}}</text>
        </view>
      </view>
      <view class="md-list-item" wx:if="{{member.notes}}">
        <view class="md-leading md-leading-surface"><text>📝</text></view>
        <view style="flex:1">
          <text style="font-size:20rpx;color:#9E9E9E;display:block;margin-bottom:4rpx">备注</text>
          <text style="font-size:28rpx;color:#1C1B1F">{{member.notes}}</text>
        </view>
      </view>
    </view>

    <!-- 交易记录 header -->
    <view class="md-card detail-tx-header">
      <view style="display:flex;align-items:center;justify-content:space-between">
        <view style="display:flex;align-items:center;gap:16rpx">
          <text style="font-size:36rpx">📊</text>
          <text style="font-size:28rpx;font-weight:600;color:#1C1B1F">交易记录</text>
        </view>
        <view class="detail-tx-count-chip">
          <text>{{transactions.length}} 笔</text>
        </view>
      </view>
    </view>

    <!-- 交易 loading -->
    <view class="md-card" wx:if="{{txLoading}}">
      <text class="loading-dots">···</text>
    </view>

    <!-- 无交易 -->
    <view class="md-card md-empty" wx:elif="{{transactions.length === 0}}">
      <text class="md-empty-icon">📋</text>
      <text class="md-empty-text">暂无交易记录</text>
    </view>

    <!-- 交易列表 -->
    <block wx:else>
      <view class="md-card tx-item" wx:for="{{transactions}}" wx:key="_id">
        <view class="tx-item-top">
          <view class="tx-type-chip {{item.type === 'recharge' ? 'chip-recharge' : 'chip-consume'}}">
            <text>{{item.type === 'recharge' ? '⬆️ 充值' : '⬇️ 消费'}}</text>
          </view>
          <text class="tx-amount {{item.type === 'recharge' ? 'amount-pos' : 'amount-neg'}}">
            {{item.type === 'recharge' ? '+' : '−'}}{{item.amount}}
          </text>
        </view>
        <view class="tx-item-bottom">
          <view>
            <text class="tx-time">🕐 {{item.timeStr}}</text>
            <text class="tx-notes" wx:if="{{item.notes}}">💬 {{item.notes}}</text>
          </view>
          <text class="tx-after-bal">余额 ¥{{item.balanceAfter}}</text>
        </view>
      </view>
    </block>

  </block>

</view>
