<!-- pages/admin/transaction/transaction.wxml -->
<view class="tx-page">

  <!-- 会员信息 -->
  <view class="member-strip" wx:if="{{member}}">
    <view class="strip-avatar">
      <text>{{member.name ? member.name[0] : '?'}}</text>
    </view>
    <view class="strip-meta">
      <text class="strip-name">{{member.name}}</text>
      <text class="strip-no">{{member.memberNo}}</text>
    </view>
    <view class="strip-balance">
      <text class="strip-bal-label">当前余额</text>
      <text class="strip-bal-amount">¥ {{member.balance}}</text>
    </view>
  </view>

  <!-- 类型标签 -->
  <view class="type-indicator {{type}}">
    <text>{{type === 'recharge' ? '充值' : '消费'}}</text>
  </view>

  <!-- 金额输入 -->
  <view class="amount-block">
    <text class="currency">¥</text>
    <input
      class="amount-input"
      type="digit"
      placeholder="0.00"
      placeholder-style="color:#DDDDDD"
      value="{{amount}}"
      bindinput="onAmountInput"
      focus="true"
    />
  </view>

  <!-- 预览余额 -->
  <view class="projected-block" wx:if="{{projectedBalance !== null}}">
    <text class="projected-label">交易后余额</text>
    <text class="projected-val {{projectedBalance < 0 ? 'negative' : ''}}">¥ {{projectedBalance}}</text>
  </view>

  <!-- 备注 -->
  <view class="notes-block">
    <text class="notes-label">备注</text>
    <textarea
      class="notes-input"
      placeholder="可选备注..."
      placeholder-style="color:#CCCCCC"
      value="{{notes}}"
      bindinput="onNotesInput"
      maxlength="100"
      auto-height
    />
  </view>

  <!-- 提交按钮 -->
  <view class="submit-area">
    <button
      class="submit-btn {{type}} {{submitting ? 'disabled' : ''}}"
      bindtap="handleSubmit"
      disabled="{{submitting}}"
    >
      {{submitting ? '处理中...' : (type === 'recharge' ? '确认充值' : '确认消费')}}
    </button>
  </view>

</view>
