/* pages/admin/transaction/transaction.wxss */
.tx-page {
  background: #F5F5F2;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 会员条 */
.member-strip {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #E0E0DC;
}

.strip-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.strip-avatar text { font-size: 28rpx; color: #FFFFFF; font-weight: 700; }

.strip-meta { flex: 1; }
.strip-name { display: block; font-size: 28rpx; font-weight: 600; color: #111111; }
.strip-no { display: block; font-size: 20rpx; color: #AAAAAA; margin-top: 4rpx; letter-spacing: 1rpx; }

.strip-balance { text-align: right; }
.strip-bal-label { display: block; font-size: 20rpx; color: #AAAAAA; letter-spacing: 1rpx; }
.strip-bal-amount { display: block; font-size: 32rpx; font-weight: 700; color: #2E6640; margin-top: 4rpx; }

/* 类型标签 */
.type-indicator {
  text-align: center;
  padding: 16rpx 40rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
}
.type-indicator.recharge { color: #2E6640; background: #EEF6F0; }
.type-indicator.consume { color: #965F30; background: #FDF5EE; }

/* 金额输入 */
.amount-block {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  padding: 48rpx 40rpx 40rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
  margin-top: 24rpx;
}

.currency {
  font-size: 52rpx;
  color: #CCCCCC;
  font-weight: 300;
  margin-right: 8rpx;
  line-height: 1;
}

.amount-input {
  flex: 1;
  font-size: 80rpx;
  font-weight: 700;
  color: #111111;
  height: 100rpx;
  letter-spacing: -2rpx;
}

/* 余额预览 */
.projected-block {
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx;
  border-bottom: 1rpx solid #E0E0DC;
}
.projected-label { font-size: 24rpx; color: #AAAAAA; letter-spacing: 1rpx; }
.projected-val { font-size: 30rpx; font-weight: 700; color: #2E6640; }
.projected-val.negative { color: #C0392B; }

/* 备注 */
.notes-block {
  background: #FFFFFF;
  margin-top: 24rpx;
  padding: 28rpx 40rpx;
  border-top: 1rpx solid #E0E0DC;
  border-bottom: 1rpx solid #E0E0DC;
}
.notes-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: #AAAAAA;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}
.notes-input {
  width: 100%;
  min-height: 100rpx;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #EEEEEA;
  padding: 0 0 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.8;
}

/* 提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #E0E0DC;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.submit-btn {
  width: 100%;
  height: 96rpx;
  border: none;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-btn::after { border: none; }
.submit-btn.recharge { background: #111111; color: #FFFFFF; }
.submit-btn.consume { background: #965F30; color: #FFFFFF; }
.submit-btn.disabled { opacity: 0.35; }
