/* pages/admin/transaction/transaction.wxss */
.tx-bento-page { background: #EDEBE3; min-height: 100vh; }

/* hero card 动态颜色 */
.hero-recharge { background: #1B2B22; }
.hero-consume  { background: #B8694A; }

.tx-hero-card {
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.tx-hero-content { display: flex; align-items: center; gap: 20rpx; }

.tx-avatar-square {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  background: rgba(250,248,243,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.tx-avatar-square text { font-size: 36rpx; color: #FAF8F3; font-weight: 700; }

.tx-hero-meta {}
.tx-hero-name { display: block; font-size: 32rpx; font-weight: 700; color: #FAF8F3; margin-top: 6rpx; }
.tx-hero-no { display: block; font-size: 20rpx; color: rgba(250,248,243,0.45); margin-top: 4rpx; letter-spacing: 1rpx; }

.tx-hero-balance {}
.tx-hero-bal-num { display: block; font-size: 52rpx; font-weight: 800; color: #FAF8F3; letter-spacing: -2rpx; margin-top: 6rpx; }

/* 金额输入 */
.amount-card {}
.amount-input-row { display: flex; align-items: center; margin: 8rpx 0 4rpx; }
.amount-currency { font-size: 52rpx; color: #B0AEA6; font-weight: 300; margin-right: 8rpx; line-height: 1; }
.amount-input-bento {
  flex: 1;
  font-size: 80rpx;
  font-weight: 800;
  color: #1B2B22;
  height: 100rpx;
  letter-spacing: -2rpx;
}

.projected-row-bento {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #E8E6DE;
}
.projected-label-bento { font-size: 22rpx; color: #B0AEA6; letter-spacing: 1rpx; }
.projected-val-bento { font-size: 28rpx; font-weight: 700; color: #2E6640; }
.projected-val-bento.negative { color: #B8694A; }

/* 备注 */
.notes-bento-card {}
.notes-input-bento {
  width: 100%;
  min-height: 100rpx;
  background: transparent;
  border: none;
  font-size: 28rpx;
  color: #2C4A38;
  line-height: 1.8;
  box-sizing: border-box;
}

/* 提交 card */
.submit-recharge { background: #1B2B22; }
.submit-consume  { background: #B8694A; }
