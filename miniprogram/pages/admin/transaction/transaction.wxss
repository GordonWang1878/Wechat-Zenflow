/* pages/admin/transaction/transaction.wxss */

/* 动态 hero */
.tx-hero {
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
}
.tx-hero-recharge { background: #3A3A3A; }
.tx-hero-consume { background: #B8694A; }

.tx-hero-label {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255,255,255,0.8);
  letter-spacing: 1rpx;
  margin-bottom: 28rpx;
}
.tx-hero-member { display: flex; align-items: center; gap: 20rpx; }
.tx-hero-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex-shrink: 0;
}
.tx-hero-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}
.tx-hero-meta { display: block; font-size: 22rpx; color: rgba(255,255,255,0.6); }

/* 金额输入 */
.tx-amount-card {}
.tx-amount-row { display: flex; align-items: baseline; gap: 8rpx; margin: 16rpx 0 8rpx; }
.tx-currency { font-size: 52rpx; color: #BDBDBD; font-weight: 300; line-height: 1; }
.tx-amount-input {
  flex: 1;
  font-size: 84rpx;
  font-weight: 700;
  color: #1C1B1F;
  height: 104rpx;
  letter-spacing: -3rpx;
  background: transparent;
}

.tx-projected-row { margin-top: 8rpx; }
.tx-projected-val { font-size: 28rpx; font-weight: 700; }
.projected-pos { color: #2E6640; }
.projected-neg { color: #B3261E; }

/* 备注 */
.tx-notes-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #1C1B1F;
  background: transparent;
  line-height: 1.8;
  box-sizing: border-box;
}

/* 提交按钮 */
.tx-submit-btn { width: 100%; height: 96rpx; font-size: 32rpx; }
.tx-submit-recharge { background: #3A3A3A; color: #FFFFFF; }
.tx-submit-consume { background: #B8694A; color: #FFFFFF; }
