/* pages/profile/profile.wxss */

.profile-hero {
  background: #3A3A3A;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}
.profile-hero-icon { font-size: 64rpx; margin-bottom: 16rpx; }
.profile-hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}
.profile-hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.6); }

.profile-tip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}
.profile-tip-icon { font-size: 26rpx; flex-shrink: 0; }
.profile-tip-text { font-size: 22rpx; color: #9E9E9E; line-height: 1.6; }

.profile-btn { width: 100%; height: 96rpx; font-size: 32rpx; }
