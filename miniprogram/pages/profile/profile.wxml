<!-- pages/profile/profile.wxml -->
<view class="md-screen">

  <!-- 英雄 header -->
  <view class="profile-hero">
    <text class="profile-hero-icon">{{isFirstSetup ? '👋' : '✏️'}}</text>
    <text class="profile-hero-title">{{isFirstSetup ? '确认您的昵称' : '修改昵称'}}</text>
    <text class="profile-hero-sub">{{isFirstSetup ? '这将作为您在本小程序的显示名称' : '更新您的显示名称'}}</text>
  </view>

  <!-- 昵称输入 -->
  <view class="md-card">
    <view class="md-field" style="margin-bottom:16rpx">
      <text class="md-field-label">👤 昵称</text>
      <view class="md-field-container">
        <input
          type="nickname"
          class="md-field-input"
          placeholder="输入或选用微信昵称"
          placeholder-style="color:#C8C8C8"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>
    </view>
    <view class="profile-tip">
      <text class="profile-tip-icon">💡</text>
      <text class="profile-tip-text">可在输入框直接修改，或点击键盘顶部快速选用微信昵称</text>
    </view>
  </view>

  <!-- 确认按钮 -->
  <view style="padding:8rpx 24rpx 40rpx">
    <view
      class="md-btn md-btn-filled profile-btn {{submitting ? 'disabled' : ''}}"
      bindtap="handleSave"
    >
      <text>{{submitting ? '保存中...' : '✅ 确认昵称'}}</text>
    </view>
  </view>

</view>
