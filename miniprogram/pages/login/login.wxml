<!-- pages/login/login.wxml -->
<view class="login-page">
  <view class="bento-grid">

    <!-- 品牌 hero：full，forest -->
    <view class="bento-card card-full card-forest brand-hero-card">
      <view class="brand-mark-bento">
        <text class="brand-char-bento">禅</text>
      </view>
      <text class="brand-name-bento">禅流中医推拿</text>
      <text class="brand-tagline-bento">专业推拿 · 调理身心</text>
      <view class="deco-dots">
        <view class="dot dot-sage"></view>
        <view class="dot dot-cream"></view>
      </view>
    </view>

    <!-- 说明 card：half，cream -->
    <view class="bento-card card-half card-cream login-desc-card">
      <text class="card-label">Login</text>
      <text class="login-desc-text">使用微信账号安全登录系统</text>
    </view>

    <!-- 登录按钮 card：half，sage -->
    <view class="bento-card card-half card-sage login-action-card">
      <text class="card-label" style="color:#2E6640">微信登录</text>
      <button
        class="btn-login-bento {{loading ? 'loading' : ''}}"
        bindtap="handleLogin"
        disabled="{{loading}}"
      >
        {{loading ? '···' : '一键进入'}}
      </button>
    </view>

    <!-- 声明 card：full，terra -->
    <view class="bento-card card-full card-terra notice-card">
      <text class="notice-text">MEMBERS ONLY · 仅向授权用户开放</text>
    </view>

  </view>
</view>
