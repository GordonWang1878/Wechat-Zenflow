<!-- pages/login/login.wxml -->
<view class="login-page">

  <!-- 品牌区 -->
  <view class="brand-area">
    <view class="brand-mark">
      <text class="brand-char">禅</text>
    </view>
    <text class="brand-name">禅流中医推拿</text>
    <text class="brand-tagline">专业推拿 · 调理身心</text>
  </view>

  <!-- 登录区 -->
  <view class="login-section">
    <text class="login-heading">登录</text>
    <text class="login-sub">使用微信账号继续</text>

    <button
      class="btn-login {{loading ? 'loading' : ''}}"
      bindtap="handleLogin"
      disabled="{{loading}}"
    >
      {{loading ? '登录中...' : '微信一键登录'}}
    </button>

    <text class="login-note">仅向授权用户开放</text>
  </view>

</view>
