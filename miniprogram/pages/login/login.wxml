<!-- pages/login/login.wxml -->
<view class="login-screen">

  <!-- 绿色英雄区 -->
  <view class="login-hero">
    <text class="login-brand">禅流</text>
    <text class="login-tagline">中医推拿工作室</text>
  </view>

  <!-- 白色底部 sheet -->
  <view class="login-sheet">
    <text class="login-sheet-title">欢迎回来</text>
    <text class="login-sheet-body">使用微信账号一键登录，开启您的健康管理之旅</text>

    <view
      class="md-btn md-btn-filled login-btn {{loading ? 'disabled' : ''}}"
      bindtap="handleLogin"
    >
      <text>{{loading ? '登录中...' : '微信一键登录'}}</text>
    </view>

    <view class="login-notice">
      <text>🔒</text>
      <text class="login-notice-text">本小程序仅限工作室会员使用</text>
    </view>
  </view>

</view>
