/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: #EDEBE3;
}

/* 品牌 hero card */
.brand-hero-card {
  min-height: 500rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48rpx;
}

.brand-mark-bento {
  width: 100rpx;
  height: 100rpx;
  border: 2rpx solid rgba(212, 230, 204, 0.5);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.brand-char-bento {
  font-size: 52rpx;
  color: #D4E6CC;
  font-weight: 800;
  line-height: 1;
}

.brand-name-bento {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #FAF8F3;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}
.brand-tagline-bento {
  display: block;
  font-size: 22rpx;
  color: rgba(250, 248, 243, 0.45);
  letter-spacing: 3rpx;
}

/* 装饰圆点 */
.deco-dots {
  position: absolute;
  top: 48rpx;
  right: 48rpx;
  display: flex;
  gap: 12rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.dot-sage { background: #D4E6CC; opacity: 0.6; }
.dot-cream { background: #FAF8F3; opacity: 0.3; }

/* 说明 card */
.login-desc-card { display: flex; flex-direction: column; justify-content: space-between; min-height: 200rpx; }
.login-desc-text {
  font-size: 26rpx;
  color: #5A7060;
  line-height: 1.7;
  margin-top: 8rpx;
}

/* 登录按钮 card */
.login-action-card { min-height: 200rpx; display: flex; flex-direction: column; justify-content: space-between; }

.btn-login-bento {
  width: 100%;
  height: 88rpx;
  background: #1B2B22;
  color: #FAF8F3;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: auto;
}
.btn-login-bento::after { border: none; }
.btn-login-bento.loading { opacity: 0.5; }

/* 声明 card */
.notice-card {
  padding: 24rpx 36rpx;
  display: flex;
  align-items: center;
}
.notice-text {
  font-size: 20rpx;
  color: rgba(250, 248, 243, 0.55);
  letter-spacing: 2rpx;
  font-weight: 600;
}
