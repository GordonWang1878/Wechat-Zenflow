/* pages/login/login.wxss */
.login-screen {
  min-height: 100vh;
  background: #2E6640;
  display: flex;
  flex-direction: column;
}

/* 英雄区 */
.login-hero {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx 64rpx;
}
.login-brand {
  font-family: Georgia, 'Palatino Linotype', Palatino, serif;
  font-size: 88rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  line-height: 1;
}
.login-tagline {
  font-family: Georgia, 'Palatino Linotype', Palatino, serif;
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  margin-top: 20rpx;
  letter-spacing: 3rpx;
}

/* 底部白色 sheet */
.login-sheet {
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 56rpx 40rpx;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}
.login-sheet-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1C1B1F;
  margin-bottom: 16rpx;
}
.login-sheet-body {
  display: block;
  font-size: 26rpx;
  color: #9E9E9E;
  line-height: 1.7;
  margin-bottom: 48rpx;
}
.login-btn { width: 100%; margin-bottom: 36rpx; }
.login-notice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
}
.login-notice-text { font-size: 24rpx; color: #BDBDBD; }
