/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: #F5F5F2;
  display: flex;
  flex-direction: column;
  padding: 0 56rpx;
  box-sizing: border-box;
}

/* 品牌区 */
.brand-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100rpx;
}

.brand-mark {
  width: 112rpx;
  height: 112rpx;
  border: 2rpx solid #111111;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.brand-char {
  font-size: 56rpx;
  color: #111111;
  font-weight: 700;
  line-height: 1;
}

.brand-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #111111;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
}

.brand-tagline {
  font-size: 22rpx;
  color: #999999;
  letter-spacing: 3rpx;
}

/* 登录区 */
.login-section {
  padding: 56rpx 0;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
}

.login-heading {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.login-sub {
  display: block;
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 52rpx;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-login::after { border: none; }
.btn-login.loading { opacity: 0.5; }

.login-note {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 28rpx;
  letter-spacing: 1rpx;
}
