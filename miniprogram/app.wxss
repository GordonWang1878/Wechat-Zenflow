/* app.wxss — Material Design 3 全局样式 */

/* ===== 基础 ===== */
page {
  background: #F5F5F5;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #1C1B1F;
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
}

/* ===== 页面容器 ===== */
.md-screen { min-height: 100vh; background: #F5F5F5; padding-bottom: 48rpx; }

/* ===== 卡片 ===== */
.md-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.06);
}
.md-card-primary {
  background: #3D7D52;
  border-radius: 0 0 36rpx 36rpx;
  padding: 48rpx 32rpx 56rpx;
  margin-bottom: 20rpx;
}
.md-card-tonal {
  background: #D4EDDA;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 16rpx;
}
.md-card-tonal-secondary {
  background: #FDEBD0;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 0 24rpx 16rpx;
}

/* ===== 列表条目 ===== */
.md-list-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  gap: 20rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.md-list-item:last-child { border-bottom: none; }

/* Leading icon 容器 */
.md-leading {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 32rpx;
}
.md-leading-primary { background: #D4EDDA; }
.md-leading-secondary { background: #FDEBD0; }
.md-leading-surface { background: #F0F0F0; }

/* ===== 按钮 ===== */
.md-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50rpx;
  height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  gap: 10rpx;
}
.md-btn-filled { background: #3D7D52; color: #FFFFFF; }
.md-btn-filled-secondary { background: #B8694A; color: #FFFFFF; }
.md-btn-tonal { background: #D4EDDA; color: #1B4332; }
.md-btn-tonal-secondary { background: #FDEBD0; color: #7B3F26; }
.md-btn-outlined { border: 2rpx solid #E0E0E0; color: #49454F; background: transparent; }
.md-btn.disabled { opacity: 0.38; }

/* ===== FAB ===== */
.md-fab {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: #3D7D52;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(46,102,64,0.4);
  font-size: 48rpx;
  color: #FFFFFF;
}

/* ===== Chips ===== */
.md-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: 500;
  gap: 8rpx;
}
.md-chip-primary { background: #D4EDDA; color: #1B4332; }
.md-chip-secondary { background: #FDEBD0; color: #7B3F26; }
.md-chip-surface { background: #F0F0F0; color: #49454F; }

/* ===== 搜索栏 ===== */
.md-search {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 50rpx;
  padding: 0 28rpx;
  height: 72rpx;
  gap: 16rpx;
  margin-top: 28rpx;
}
.md-search-input {
  flex: 1;
  font-size: 27rpx;
  color: #FFFFFF;
  background: transparent;
}

/* ===== 表单字段 ===== */
.md-field { margin-bottom: 24rpx; }
.md-field-label {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  color: #3D7D52;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
}
.md-field-container {
  border: 1.5rpx solid #E0E0E0;
  border-radius: 14rpx;
  padding: 18rpx 24rpx;
  background: #FAFAFA;
}
.md-field-input {
  width: 100%;
  font-size: 28rpx;
  color: #1C1B1F;
  height: 52rpx;
  background: transparent;
  box-sizing: border-box;
}
.md-field-textarea {
  width: 100%;
  min-height: 100rpx;
  font-size: 28rpx;
  color: #1C1B1F;
  background: transparent;
  line-height: 1.8;
  box-sizing: border-box;
}

/* ===== 分割线 ===== */
.md-divider { height: 1rpx; background: #F0F0F0; margin: 8rpx 0; }

/* ===== Section 标题 ===== */
.md-section-title {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #9E9E9E;
  padding: 28rpx 32rpx 12rpx;
  text-transform: uppercase;
}

/* ===== Loading / Empty ===== */
.loading-dots {
  display: block;
  text-align: center;
  font-size: 40rpx;
  color: #BDBDBD;
  letter-spacing: 8rpx;
  padding: 60rpx 0;
}
.md-empty {
  text-align: center;
  padding: 80rpx 40rpx;
}
.md-empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.md-empty-text { font-size: 27rpx; color: #9E9E9E; }
