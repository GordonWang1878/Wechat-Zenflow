/* app.wxss —— 全局样式 */

/* ===== 页面基础 ===== */
page {
  background-color: #f5f5f0;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #333;
  font-size: 28rpx;
}

/* ===== 布局 ===== */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 卡片 ===== */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ===== 按钮 ===== */
.btn-primary {
  background: #4a7c59;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 0;
  width: 100%;
  text-align: center;
}
.btn-primary::after { border: none; }

.btn-secondary {
  background: #fff;
  color: #4a7c59;
  border: 2rpx solid #4a7c59;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  width: 100%;
  text-align: center;
}
.btn-secondary::after { border: none; }

.btn-danger {
  background: #e53935;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 24rpx 0;
  width: 100%;
  text-align: center;
}
.btn-danger::after { border: none; }

.btn-sm {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  width: auto;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: #e0ddd5;
  margin: 24rpx 0;
}

/* ===== 标题 ===== */
.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4a7c59;
  margin-bottom: 16rpx;
  display: block;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}
.tag-admin {
  background: #e8f5e9;
  color: #2e7d32;
}
.tag-normal {
  background: #f5f5f0;
  color: #757575;
}

/* ===== 列表项 ===== */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0ede5;
}
.list-item:last-child { border-bottom: none; }

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #bbb;
}
.empty-state .empty-icon { font-size: 100rpx; }
.empty-state .empty-text {
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 28rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.form-label .required {
  color: #e53935;
  margin-left: 4rpx;
}
.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}
.form-input.error-border { border-color: #e53935; }
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8f8f5;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}
