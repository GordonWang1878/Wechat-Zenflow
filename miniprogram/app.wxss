/* app.wxss —— Advanced Minimalism 全局样式 */

/* ===== 基础 ===== */
page {
  background: #F5F5F2;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #111111;
  font-size: 28rpx;
  -webkit-font-smoothing: antialiased;
}

/* ===== 通用布局 ===== */
.container {
  padding: 0 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background: #E0E0DC;
  margin: 32rpx 0;
}

/* ===== 按钮 ===== */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: #111111;
  color: #FFFFFF;
  border: none;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-primary::after { border: none; }
.btn-primary.disabled { opacity: 0.35; }

.btn-secondary {
  width: 100%;
  height: 96rpx;
  background: transparent;
  color: #111111;
  border: 1rpx solid #111111;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-secondary::after { border: none; }

.btn-danger {
  width: 100%;
  height: 96rpx;
  background: transparent;
  color: #C0392B;
  border: 1rpx solid #C0392B;
  border-radius: 4rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-danger::after { border: none; }

/* ===== 表单 ===== */
.form-group { margin-bottom: 36rpx; }

.form-label {
  display: block;
  font-size: 22rpx;
  color: #888888;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}
.form-label .required { color: #C0392B; margin-left: 4rpx; }

.form-input {
  width: 100%;
  height: 80rpx;
  background: #FFFFFF;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 0;
  font-size: 30rpx;
  color: #111111;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #FFFFFF;
  border: none;
  border-bottom: 1rpx solid #E0E0DC;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #111111;
  box-sizing: border-box;
  line-height: 1.7;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #CCCCCC;
}
.empty-state .empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-state .empty-text { font-size: 26rpx; letter-spacing: 1rpx; }

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #AAAAAA;
  font-size: 40rpx;
  letter-spacing: 8rpx;
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  border: 1rpx solid currentColor;
  border-radius: 2rpx;
}
